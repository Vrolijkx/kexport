root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
ktlint_code_style = intellij_idea
ij_kotlin_packages_to_use_import_on_demand = com.google.devtools.ksp.processing,com.google.devtools.ksp.symbol
